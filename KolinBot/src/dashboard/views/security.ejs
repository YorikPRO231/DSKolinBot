<%
  title = 'Security';
  currentPage = 'security';
%>

<%- include('layout', { part: 'header', title: title, currentPage: currentPage, user: user }) %>

<link rel="stylesheet" href="/css/security.css">

<div class="page-header">
    <h1><i class="fas fa-shield-alt"></i> Security</h1>
</div>

<div id="alertsTab" class="tab-content active">
    <div class="filter-bar">
        <div class="custom-dropdown" id="typeDropdown">
            <div class="dropdown-trigger" onclick="SecurityModule.toggleDropdown()">
                <span id="dropdownSelectedValue"><i class="fas fa-filter text-dim"></i> Все типы</span>
                <i class="fas fa-chevron-down arrow"></i>
            </div>
            <div class="dropdown-menu">
                <div class="dropdown-item active" data-value="ALL" onclick="SecurityModule.selectDropdownItem(this)">
                    <i class="fas fa-list-ul"></i> Все типы
                </div>
                <div class="dropdown-item" data-value="Bots" onclick="SecurityModule.selectDropdownItem(this)">
                    <i class="fas fa-robot text-bots"></i> Боты
                </div>
                <div class="dropdown-item" data-value="Cheats" onclick="SecurityModule.selectDropdownItem(this)">
                    <i class="fas fa-gamepad text-cheats"></i> Читы
                </div>
            </div>
        </div>
    
        <input type="text" id="alertSearch" placeholder="Поиск по статику игрока..." oninput="SecurityModule.debouncedLoadAlerts()">
        
        <button class="btn-primary" onclick="openAddPlayerModal()">
            <i class="fas fa-plus"></i> Добавить игрока
        </button>
        <button class="btn-secondary" onclick="copyAllStats()">
            <i class="fas fa-copy"></i> Копировать статики
        </button>
    </div>

    <div class="card table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Статик</th>
                    <th>Тип</th>
                    <th>Причина</th>
                    <th>Кто добавил</th>
                    <th style="text-align: center;">Кол-во</th>
                    <th>Дата</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody id="alertsList">
                <tr>
                    <td colspan="7" class="loading">
                        <i class="fas fa-spinner fa-spin"></i> Загрузка...
                    </td>
                </tr>
            </tbody>
        </table>
        
    </div>
</div>

<div id="pagination" class="pagination" style="display: none;">
    <button class="page-btn" id="prevPageBtn" onclick="changePage(-1)">← Назад</button>
    <span id="pageInfo" class="page-info"></span>
    <button class="page-btn" id="nextPageBtn" onclick="changePage(1)">Вперед →</button>
</div>

<div id="confirmModal" class="modal">
    <div class="modal-content modal-sm text-center">
        <i class="fas fa-exclamation-triangle modal-icon-warning"></i>
        <h3 id="confirmTitle">Подтверждение</h3>
        <p id="confirmMessage">Вы уверены?</p>
        <div class="modal-buttons confirm-buttons">
            <button id="confirmCancelBtn" type="button" class="btn-cancel">Отмена</button>
            <button id="confirmActionBtn" class="btn-danger">Подтвердить</button>
        </div>
    </div>
</div>

<div id="detailsModal" class="modal">
    <div class="modal-content modal-md">
        <h3 class="modal-title">Детали</h3>
        <div id="detailsContent" class="modal-scroll-content"></div>
        <div class="modal-buttons">
            <button type="button" class="btn-primary" onclick="closeModal('detailsModal')" style="width: 100%;">Закрыть</button>
        </div>
    </div>
</div>

<div id="addPlayerModal" class="modal">
    <div class="modal-content modal-md">
        <div class="modal-header">
            <h3>
                <i class="fas fa-user-plus"></i>
                Добавить игрока
            </h3>
            <button class="modal-close" onclick="closeModal('addPlayerModal')">
                <i class="fas fa-times"></i>
            </button>
        </div>
        
        <div class="modal-body">
            <div class="form-group">
                <label>Тип нарушения</label>
                <div class="custom-dropdown" id="alertTypeDropdown">
                    <div class="dropdown-trigger" onclick="SecurityModule.toggleAlertTypeDropdown()">
                        <span id="alertTypeSelectedValue">
                            <i class="fas fa-gamepad text-cheats"></i> Читы
                        </span>
                        <i class="fas fa-chevron-down arrow"></i>
                    </div>
                    <div class="dropdown-menu">
                        <div class="dropdown-item" data-value="Cheats" onclick="SecurityModule.selectAlertType(this)">
                            <i class="fas fa-gamepad text-cheats"></i> Читы
                        </div>
                        <div class="dropdown-item" data-value="Bots" onclick="SecurityModule.selectAlertType(this)">
                            <i class="fas fa-robot text-bots"></i> Боты
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="form-group">
                <label>Статик игрока</label>
                <input type="text" id="playerStatic" class="form-control" placeholder="Введите ID игрока">
            </div>
            
            <div class="form-group">
                <label>Причина</label>
                <textarea id="playerReason" rows="4" class="form-control" placeholder="Укажите причину проверки"></textarea>
            </div>
        </div>
        
        <div class="modal-footer">
            <button type="button" class="btn-secondary" onclick="closeModal('addPlayerModal')">
                <i class="fas fa-times"></i> Отмена
            </button>
            <button type="button" class="btn-primary" onclick="addPlayerToSecurity()">
                <i class="fas fa-plus"></i> Добавить игрока
            </button>
        </div>
    </div>
</div>

<div id="notificationModal" class="modal">
    <div class="modal-content modal-sm text-center">
        <i id="notificationIcon" class="fas fa-check-circle"></i>
        <h3 id="notificationTitle">Успех</h3>
        <p id="notificationMessage">Действие выполнено</p>
        <div class="modal-buttons" style="justify-content: center;">
            <button type="button" class="btn-primary" onclick="closeModal('notificationModal')">Закрыть</button>
        </div>
    </div>
</div>

<script src="/js/security.js"></script>

<%- include('layout', { part: 'footer' }) %>