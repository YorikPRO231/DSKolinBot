<%
  title = 'Управление правами';
  currentPage = 'permissions';
%>

<%- include('../layout', { part: 'header', title: title, currentPage: currentPage, user: user }) %>

<link rel="stylesheet" href="/css/permissions.css">

<div class="page-header">
    <h1><i class="fas fa-lock"></i> Управление правами доступа</h1>
    <div class="header-actions">
        <button class="btn-primary" onclick="openCreateRoleModal()">
            <i class="fas fa-plus"></i> Создать роль
        </button>
    </div>
</div>

<div class="card">
    <div class="tabs">
        <button class="tab-btn active" onclick="showTab(event, 'roles')">
            <i class="fas fa-users"></i> Роли
        </button>
        <button class="tab-btn" onclick="showTab(event, 'users')">
            <i class="fas fa-user"></i> Пользователи
        </button>
    </div>

    <div id="rolesTab" class="tab-content active">
        <div class="roles-list">
            <% roles.forEach(role => { %>
                <div class="role-card">
                    <div class="role-header">
                        <div class="role-info">
                            <h3><%= role.role_name %></h3>
                            <span class="role-id"><%= role.role_id %></span>
                        </div>
                        <button class="btn-icon delete-role-btn" onclick="deleteRole('<%= role.role_id %>', '<%= role.role_name %>')" title="Удалить роль">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                    <div class="permissions-grid">
                        <% permissions.forEach(perm => { %>
                            <label class="permission-checkbox">
                                <input type="checkbox" 
                                    data-role="<%= role.role_id %>"
                                    data-permission="<%= perm.permission_key %>"
                                    <%= (role.permissions || '').includes(perm.permission_key) ? 'checked' : '' %>
                                    onchange="togglePermission(this, '<%= role.role_id %>', '<%= perm.permission_key %>')">
                                <span class="permission-name"><%= perm.permission_name %></span>
                                <span class="permission-desc"><%= perm.description %></span>
                            </label>
                        <% }) %>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <div id="usersTab" class="tab-content">
        <div class="filter-bar">
            <input type="text" id="userIdInput" class="search-input" placeholder="Discord ID пользователя">
            <select id="userRoleSelect" class="search-input">
                <option value="">Выберите роль</option>
                <% roles.forEach(role => { %>
                    <option value="<%= role.role_id %>"><%= role.role_name %></option>
                <% }) %>
            </select>
            <button class="btn-primary" onclick="addUserToRole()">
                <i class="fas fa-user-plus"></i> Добавить
            </button>
        </div>
        
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Пользователь</th>
                        <th>ID</th>
                        <th>Роли</th>
                        <th style="width: 80px;">Действия</th>
                    </tr>
                </thead>
                <tbody id="usersList">
                    <tr>
                        <td colspan="4" class="loading-text">
                            <i class="fas fa-spinner fa-spin"></i> Загрузка...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="createRoleModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:10001; justify-content:center; align-items:center;">
    <div class="modal-content" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; width: 500px; max-width: 90%;">
        <div style="display:flex; justify-content:space-between; align-items:center; padding:1rem 1.5rem; border-bottom:1px solid var(--border);">
            <h3 style="margin:0; color:var(--accent);"><i class="fas fa-plus-circle"></i> Создать роль</h3>
            <button onclick="closeCreateRoleModal()" style="background:none; border:none; color:var(--text-dim); font-size:1.5rem; cursor:pointer; padding:0; width:32px; height:32px; border-radius:6px;">&times;</button>
        </div>
        <div style="padding:1.5rem;">
            <div style="margin-bottom:1rem;">
                <label style="display:block; margin-bottom:0.5rem; color:var(--text-dim); font-size:0.8rem;">ID роли (Discord Role ID)</label>
                <input type="text" id="newRoleId" class="search-input" style="width:100%;" placeholder="123456789012345678">
            </div>
            <div style="margin-bottom:1rem;">
                <label style="display:block; margin-bottom:0.5rem; color:var(--text-dim); font-size:0.8rem;">Название роли</label>
                <input type="text" id="newRoleName" class="search-input" style="width:100%;" placeholder="Модератор">
            </div>
        </div>
        <div style="display:flex; justify-content:flex-end; gap:0.8rem; padding:1rem 1.5rem; border-top:1px solid var(--border);">
            <button class="btn-secondary" onclick="closeCreateRoleModal()">Отмена</button>
            <button class="btn-primary" onclick="createRole()">Создать</button>
        </div>
    </div>
</div>

<div id="confirmModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:10001; justify-content:center; align-items:center;">
    <div class="modal-content" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; width: 400px; max-width: 90%; text-align: center;">
        <div style="display:flex; justify-content:space-between; align-items:center; padding:1rem 1.5rem; border-bottom:1px solid var(--border);">
            <h3 style="margin:0; color:var(--accent);"><i class="fas fa-exclamation-triangle"></i> Подтверждение</h3>
            <button onclick="closeConfirmModal()" style="background:none; border:none; color:var(--text-dim); font-size:1.5rem; cursor:pointer; padding:0; width:32px; height:32px; border-radius:6px;">&times;</button>
        </div>
        <div style="padding:1.5rem;">
            <p id="confirmMessage" style="color: var(--text-dim);">Вы уверены?</p>
        </div>
        <div style="display:flex; justify-content:center; gap:0.8rem; padding:1rem 1.5rem; border-top:1px solid var(--border);">
            <button class="btn-secondary" onclick="closeConfirmModal()">Отмена</button>
            <button class="btn-primary" onclick="executeConfirm()">Подтвердить</button>
        </div>
    </div>
</div>

<div id="notificationModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:10001; justify-content:center; align-items:center;">
    <div class="modal-content" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; width: 350px; max-width: 90%; text-align: center;">
        <div style="display:flex; justify-content:space-between; align-items:center; padding:1rem 1.5rem; border-bottom:1px solid var(--border);">
            <h3 style="margin:0;">Уведомление</h3>
            <button onclick="closeNotificationModal()" style="background:none; border:none; color:var(--text-dim); font-size:1.5rem; cursor:pointer; padding:0; width:32px; height:32px; border-radius:6px;">&times;</button>
        </div>
        <div style="padding:1.5rem;">
            <i id="notificationIcon" class="fas fa-check-circle" style="font-size: 3rem; margin-bottom: 1rem;"></i>
            <h3 id="notificationTitle" style="margin-bottom:0.5rem;">Успех</h3>
            <p id="notificationMessage" style="color: var(--text-dim);">Действие выполнено</p>
        </div>
        <div style="display:flex; justify-content:center; padding:1rem 1.5rem; border-top:1px solid var(--border);">
            <button class="btn-primary" onclick="closeNotificationModal()">Закрыть</button>
        </div>
    </div>
</div>

<style>
.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
}

.page-header h1 {
    font-size: 1.8rem;
    font-weight: 600;
    margin: 0;
}

.page-header h1 i {
    color: var(--accent);
    margin-right: 12px;
}

.header-actions {
    display: flex;
    gap: 1rem;
}

.tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0;
}

.tab-btn {
    background: transparent;
    border: none;
    padding: 0.75rem 1.5rem;
    color: var(--text-dim);
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.2s;
    position: relative;
    border-radius: 8px 8px 0 0;
}

.tab-btn:hover {
    color: var(--text-main);
    background: rgba(255, 107, 0, 0.05);
}

.tab-btn.active {
    color: var(--accent);
}

.tab-btn.active::after {
    content: "";
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent);
}

.tab-content {
    display: none;
    animation: fadeIn 0.3s ease;
}

.tab-content.active {
    display: block;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.roles-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.role-card {
    background: var(--bg-main);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.2s;
}

.role-card:hover {
    border-color: var(--accent);
}

.role-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    background: rgba(255, 107, 0, 0.05);
    border-bottom: 1px solid var(--border);
}

.role-info {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
}

.role-info h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0;
}

.role-id {
    font-size: 0.7rem;
    color: var(--text-dim);
    background: rgba(255, 255, 255, 0.05);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-family: monospace;
}

.delete-role-btn {
    color: var(--danger);
    background: transparent;
    border: none;
    padding: 0.5rem;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
}

.delete-role-btn:hover {
    background: rgba(231, 76, 60, 0.15);
    transform: scale(1.05);
}

.permissions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.5rem;
    padding: 1rem 1.5rem;
}

.permission-checkbox {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.6rem;
    cursor: pointer;
    border-radius: 8px;
    transition: background 0.2s;
}

.permission-checkbox:hover {
    background: rgba(255, 255, 255, 0.03);
}

.permission-checkbox input {
    cursor: pointer;
    width: 18px;
    height: 18px;
    accent-color: var(--accent);
}

.permission-name {
    font-size: 0.85rem;
    font-weight: 500;
    min-width: 140px;
    color: var(--text-main);
}

.permission-desc {
    font-size: 0.7rem;
    color: var(--text-dim);
}

.filter-bar {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: var(--bg-card);
    border-radius: 12px;
    border: 1px solid var(--border);
    flex-wrap: wrap;
    align-items: center;
}

.filter-bar .search-input {
    flex: 1;
    min-width: 200px;
}

.table-wrapper {
    overflow-x: auto;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg-card);
}

.data-table {
    width: 100%;
    border-collapse: collapse;
}

.data-table th {
    text-align: left;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.2);
    color: var(--text-dim);
    font-size: 0.75rem;
    text-transform: uppercase;
    font-weight: 600;
    border-bottom: 1px solid var(--border);
}

.data-table td {
    padding: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    vertical-align: middle;
}

.data-table tr:last-child td {
    border-bottom: none;
}

.data-table tr:hover {
    background: rgba(255, 255, 255, 0.02);
}

.user-info-cell {
    display: flex;
    align-items: center;
    gap: 10px;
}

.user-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), #e66000);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: white;
}

.user-nickname {
    font-weight: 600;
    color: var(--text-main);
}

.user-id-small {
    font-size: 0.7rem;
    color: var(--text-dim);
    font-family: monospace;
}

.user-roles {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.user-role-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 107, 0, 0.15);
    color: var(--accent);
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 500;
}

.user-role-badge button {
    background: none;
    border: none;
    color: var(--danger);
    cursor: pointer;
    padding: 0;
    font-size: 0.7rem;
    transition: transform 0.2s;
}

.user-role-badge button:hover {
    transform: scale(1.1);
}

.btn-primary {
    background: var(--accent);
    color: white;
    border: none;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.btn-primary:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
}

.btn-secondary {
    background: rgba(255, 255, 255, 0.08);
    color: var(--text-main);
    border: 1px solid var(--border);
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.btn-secondary:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--accent);
}

.btn-icon {
    background: transparent;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 6px;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.btn-icon:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--accent);
}

.search-input {
    background: var(--bg-main);
    border: 1px solid var(--border);
    color: var(--text-main);
    padding: 0.7rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    transition: all 0.2s;
}

.search-input:focus {
    outline: none;
    border-color: var(--accent);
}

.loading-text {
    text-align: center;
    padding: 3rem;
    color: var(--text-dim);
}

.loading-text i {
    margin-right: 8px;
}
</style>

<script>
    let pendingConfirm = null;
    let pendingConfirmAction = null;
    let userNicknames = {};
    
    function showTab(event, tabName) {
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.remove('active');
        });
        event.target.classList.add('active');
        
        document.querySelectorAll('.tab-content').forEach(content => {
            content.classList.remove('active');
        });
        document.getElementById(tabName + 'Tab').classList.add('active');
        
        if (tabName === 'users') {
            loadUsers();
        }
    }
    
    function openCreateRoleModal() {
        document.getElementById('createRoleModal').style.display = 'flex';
    }
    
    function closeCreateRoleModal() {
        document.getElementById('createRoleModal').style.display = 'none';
    }
    
    function openConfirmModal(message, onConfirm) {
        document.getElementById('confirmMessage').innerHTML = message;
        pendingConfirmAction = onConfirm;
        document.getElementById('confirmModal').style.display = 'flex';
    }
    
    function closeConfirmModal() {
        document.getElementById('confirmModal').style.display = 'none';
        pendingConfirmAction = null;
    }
    
    function executeConfirm() {
        if (pendingConfirmAction) {
            pendingConfirmAction();
            closeConfirmModal();
        }
    }
    
    function openNotificationModal(message, isError = false) {
        const modal = document.getElementById('notificationModal');
        const icon = document.getElementById('notificationIcon');
        const title = document.getElementById('notificationTitle');
        const msg = document.getElementById('notificationMessage');
        
        if (isError) {
            icon.className = 'fas fa-exclamation-circle';
            icon.style.color = 'var(--danger)';
            title.textContent = 'Ошибка';
        } else {
            icon.className = 'fas fa-check-circle';
            icon.style.color = 'var(--success)';
            title.textContent = 'Успех';
        }
        msg.innerHTML = message;
        modal.style.display = 'flex';
        
        setTimeout(() => {
            closeNotificationModal();
        }, 3000);
    }
    
    function closeNotificationModal() {
        document.getElementById('notificationModal').style.display = 'none';
    }
    
    async function fetchUserNickname(userId) {
        if (userNicknames[userId]) return userNicknames[userId];
        
        try {
            const response = await fetch(`/api/discord/user/nickname/${userId}`);
            const data = await response.json();
            const nickname = data.nickname || userId;
            userNicknames[userId] = nickname;
            return nickname;
        } catch (error) {
            console.error('Error fetching nickname:', error);
            return userId;
        }
    }
    
    async function togglePermission(checkbox, roleId, permissionKey) {
        const isChecked = checkbox.checked;
        
        const response = await fetch(`/admin/permissions/api/roles/${roleId}/permissions/${permissionKey}`, {
            method: isChecked ? 'POST' : 'DELETE',
            headers: { 'Content-Type': 'application/json' }
        });
        
        if (!response.ok) {
            openNotificationModal('Ошибка при сохранении прав', true);
            checkbox.checked = !isChecked;
        } else {
            openNotificationModal('Права сохранены');
        }
    }
    
    async function createRole() {
        const roleId = document.getElementById('newRoleId').value.trim();
        const roleName = document.getElementById('newRoleName').value.trim();
        
        if (!roleId || !roleName) {
            openNotificationModal('Заполните все поля', true);
            return;
        }
        
        const response = await fetch('/admin/permissions/api/roles', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ roleId, roleName })
        });
        
        if (response.ok) {
            openNotificationModal('Роль создана');
            setTimeout(() => location.reload(), 1500);
        } else {
            openNotificationModal('Ошибка при создании роли', true);
        }
        closeCreateRoleModal();
    }
    
    async function deleteRole(roleId, roleName) {
        openConfirmModal(`Вы уверены, что хотите удалить роль "${roleName}"?`, async () => {
            const response = await fetch(`/admin/permissions/api/roles/${roleId}`, {
                method: 'DELETE'
            });
            
            if (response.ok) {
                openNotificationModal('Роль удалена');
                setTimeout(() => location.reload(), 1500);
            } else {
                openNotificationModal('Ошибка при удалении роли', true);
            }
        });
    }
    
    async function loadUsers() {
        try {
            const response = await fetch('/admin/permissions/api/users');
            const data = await response.json();
            
            if (data.success && data.users && data.users.length > 0) {
                for (const user of data.users) {
                    user.nickname = await fetchUserNickname(user.user_id);
                }
                renderUsers(data.users);
            } else {
                document.getElementById('usersList').innerHTML = '<td><td colspan="4" class="empty-text">Нет пользователей</td></tr>';
            }
        } catch (error) {
            console.error('Error loading users:', error);
            document.getElementById('usersList').innerHTML = '<tr><td colspan="4" class="error-text">Ошибка загрузки</td></tr>';
        }
    }
    
    function renderUsers(users) {
        const tbody = document.getElementById('usersList');
        if (!users || users.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" class="empty-text">Нет пользователей</td></tr>';
            return;
        }
        
        tbody.innerHTML = users.map(user => {
            const avatarLetter = (user.nickname && user.nickname !== user.user_id) ? user.nickname.charAt(0).toUpperCase() : 'U';
            return `
                <tr>
                    <td>
                        <div class="user-info-cell">
                            <div class="user-avatar">${escapeHtml(avatarLetter)}</div>
                            <div>
                                <div class="user-nickname">${escapeHtml(user.nickname)}</div>
                                <div class="user-id-small">${escapeHtml(user.user_id)}</div>
                            </div>
                        </div>
                      </td>
                      <td><code>${escapeHtml(user.user_id)}</code></td>
                      <td>
                        <div class="user-roles">
                            ${user.roles.map(role => `
                                <span class="user-role-badge">
                                    ${escapeHtml(role.role_name)}
                                    <button onclick="removeUserFromRole('${escapeHtml(user.user_id)}', '${escapeHtml(role.role_id)}')" title="Удалить роль">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </span>
                            `).join('')}
                            ${user.roles.length === 0 ? '<span class="user-role-badge" style="background: rgba(255,255,255,0.05);">Нет ролей</span>' : ''}
                        </div>
                      </td>
                      <td>
                        <button class="btn-icon" onclick="openAddRoleToUserModal('${escapeHtml(user.user_id)}')" title="Добавить роль">
                            <i class="fas fa-plus"></i>
                        </button>
                      </td>
                </tr>
            `;
        }).join('');
    }
    
    async function addUserToRole() {
        const userId = document.getElementById('userIdInput').value.trim();
        const roleId = document.getElementById('userRoleSelect').value;
        
        if (!userId || !roleId) {
            openNotificationModal('Выберите пользователя и роль', true);
            return;
        }
        
        const response = await fetch('/admin/permissions/api/users/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId, roleId })
        });
        
        if (response.ok) {
            openNotificationModal('Пользователь добавлен к роли');
            document.getElementById('userIdInput').value = '';
            document.getElementById('userRoleSelect').value = '';
            loadUsers();
        } else {
            openNotificationModal('Ошибка при добавлении пользователя', true);
        }
    }
    
    async function removeUserFromRole(userId, roleId) {
        openConfirmModal(`Удалить роль у пользователя ${userId}?`, async () => {
            const response = await fetch(`/admin/permissions/api/users/${userId}/roles/${roleId}`, {
                method: 'DELETE'
            });
            
            if (response.ok) {
                openNotificationModal('Роль удалена у пользователя');
                loadUsers();
            } else {
                openNotificationModal('Ошибка при удалении роли', true);
            }
        });
    }
    
    function openAddRoleToUserModal(userId) {
        const select = document.getElementById('userRoleSelect');
        const input = document.getElementById('userIdInput');
        input.value = userId;
        select.focus();
        openNotificationModal(`Введите ID пользователя и выберите роль`, false);
    }
    
    function escapeHtml(str) {
        if (!str) return '';
        return String(str).replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }
    
    window.openCreateRoleModal = openCreateRoleModal;
    window.closeCreateRoleModal = closeCreateRoleModal;
    window.closeConfirmModal = closeConfirmModal;
    window.closeNotificationModal = closeNotificationModal;
</script>

