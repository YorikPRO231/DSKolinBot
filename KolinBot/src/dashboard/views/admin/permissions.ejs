<%
  title = 'Управление правами';
  currentPage = 'permissions';
%>

<%- include('../layout', { part: 'header', title: title, currentPage: currentPage, user: user }) %>

<link rel="stylesheet" href="/css/permissions.css">

<div class="page-header">
    <h1><i class="fas fa-lock"></i> Управление правами доступа</h1>
    <div class="header-actions">
        <button class="btn-primary" onclick="PermissionsModule.openCreateRoleModal()">
            <i class="fas fa-plus"></i> Создать роль
        </button>
    </div>
</div>

<div class="card" style="padding: 1.5rem;">
    <div class="tabs">
        <button class="tab-btn active" onclick="PermissionsModule.showTab(event, 'roles')">
            <i class="fas fa-users"></i> Роли
        </button>
        <button class="tab-btn" onclick="PermissionsModule.showTab(event, 'users')">
            <i class="fas fa-user"></i> Пользователи
        </button>
    </div>

    <div id="rolesTab" class="tab-content active">
        <div class="roles-list">
            <% roles.forEach(role => { %>
                <div class="role-card">
                    <div class="role-header">
                        <div class="role-info">
                            <h3><%= role.role_name %></h3>
                            <span class="role-id"><%= role.role_id %></span>
                        </div>
                        <button class="btn-icon delete-role-btn" onclick="PermissionsModule.deleteRole('<%= role.role_id %>', '<%= role.role_name %>')" title="Удалить роль">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                    <div class="permissions-grid">
                        <% permissions.forEach(perm => { %>
                            <label class="permission-switch-block <%= (role.permissions || '').includes(perm.permission_key) ? 'is-active' : '' %>">
                                <div class="switch-control">
                                    <input type="checkbox" 
                                           data-role="<%= role.role_id %>"
                                           data-permission="<%= perm.permission_key %>"
                                           <%= (role.permissions || '').includes(perm.permission_key) ? 'checked' : '' %>
                                           onchange="PermissionsModule.togglePermission(this, '<%= role.role_id %>', '<%= perm.permission_key %>')">
                                    <span class="switch-slider"></span>
                                </div>
                                <div class="permission-meta">
                                    <span class="permission-name"><%= perm.permission_name %></span>
                                    <span class="permission-desc"><%= perm.description %></span>
                                </div>
                            </label>
                        <% }) %>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <div id="usersTab" class="tab-content">
    <div class="filter-bar">
        <input type="text" id="userIdInput" class="search-input" placeholder="Discord ID пользователя">
        
        <div class="custom-dropdown-perm" id="userRoleDropdown">
            <div class="dropdown-trigger-perm" onclick="PermissionsModule.toggleRoleDropdown()">
                <span id="userRoleSelectedValue">Выберите роль</span>
                <i class="fas fa-chevron-down arrow"></i>
            </div>
            <div class="dropdown-menu-perm">
                <% roles.forEach(role => { %>
                    <div class="dropdown-item-perm" data-value="<%= role.role_id %>" data-name="<%= role.role_name %>">
                        <%= role.role_name %>
                    </div>
                <% }) %>
            </div>
        </div>
        
        <button class="btn-primary" onclick="PermissionsModule.addUserToRole()">
            <i class="fas fa-user-plus"></i> Добавить
        </button>
    </div>
    
    <div class="table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Пользователь</th>
                    <th>ID</th>
                    <th>Роли</th>
                    <th style="width: 80px; text-align: center;">Действия</th>
                </tr>
            </thead>
            <tbody id="usersList">
                <tr>
                    <td colspan="4" class="loading-text">
                        <i class="fas fa-spinner fa-spin"></i> Загрузка списка пользователей...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
</div>

<div id="createRoleModal" class="modal-blur-overlay" style="display:none;">
    <div class="modal-content-box">
        <div class="modal-header-flex">
            <h3><i class="fas fa-plus-circle"></i> Создать роль</h3>
            <button onclick="PermissionsModule.closeCreateRoleModal()" class="close-modal-cross">&times;</button>
        </div>
        <div class="modal-body-padding">
            <div style="margin-bottom:1.2rem;">
                <label class="modal-input-label">ID роли (Discord Role ID)</label>
                <input type="text" id="newRoleId" class="search-input" style="width:100%;" placeholder="123456789012345678">
            </div>
            <div style="margin-bottom:0.5rem;">
                <label class="modal-input-label">Название роли</label>
                <input type="text" id="newRoleName" class="search-input" style="width:100%;" placeholder="Модератор">
            </div>
        </div>
        <div class="modal-footer-actions">
            <button class="btn-secondary" onclick="PermissionsModule.closeCreateRoleModal()">Отмена</button>
            <button class="btn-primary" onclick="PermissionsModule.createRole()">Создать</button>
        </div>
    </div>
</div>

<div id="confirmModal" class="modal-blur-overlay" style="display:none;">
    <div class="modal-content-box" style="width: 420px; text-align: center;">
        <div class="modal-header-flex">
            <h3 style="color: var(--danger);"><i class="fas fa-exclamation-triangle"></i> Подтверждение</h3>
            <button onclick="PermissionsModule.closeConfirmModal()" class="close-modal-cross">&times;</button>
        </div>
        <div class="modal-body-padding">
            <p id="confirmMessage" style="color: var(--text-dim); margin: 0; line-height: 1.5;"></p>
        </div>
        <div class="modal-footer-actions" style="justify-content: center;">
            <button class="btn-secondary" onclick="PermissionsModule.closeConfirmModal()">Отмена</button>
            <button class="btn-primary" style="background: var(--danger);" onclick="PermissionsModule.executeConfirm()">Подтвердить</button>
        </div>
    </div>
</div>

<div id="notificationModal" class="modal-blur-overlay" style="display:none;">
    <div class="modal-content-box" style="width: 360px; text-align: center;">
        <div class="modal-body-padding" style="padding: 2rem 1.5rem 1.5rem;">
            <i id="notificationIcon" class="fas fa-check-circle" style="font-size: 3.5rem; margin-bottom: 1.2rem; transition: color 0.2s;"></i>
            <h3 id="notificationTitle" style="margin: 0 0 0.5rem 0; font-size: 1.3rem;">Успех</h3>
            <p id="notificationMessage" style="color: var(--text-dim); margin: 0; font-size: 0.9rem; line-height: 1.4;"></p>
        </div>
        <div class="modal-footer-actions" style="justify-content: center; border-top: none; padding-top: 0;">
            <button class="btn-primary" style="min-width: 100px;" onclick="PermissionsModule.closeNotificationModal()">ОК</button>
        </div>
    </div>
</div>

<script src="/js/permissions.js"></script>

<%- include('../layout', { part: 'footer' }) %>