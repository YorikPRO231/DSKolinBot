<%- include('layout', { part: 'header', title: 'Проверки', currentPage: 'inspections' }) %>

<link rel="stylesheet" href="/css/inspections.css">

<div class="page-header">
    <h1>Реестр проверок</h1>
</div>

<div class="search-card">
    <h3><i class="fas fa-magnifying-glass"></i> Поиск по базе данных</h3>
    <div class="search-container">
        <input type="text" id="searchInput" placeholder="Введите номер паспорта или Discord ID игрока...">
        <button class="btn btn-primary" onclick="InspectionsModule.searchRecords()">
            <i class="fas fa-search"></i> Найти записи
        </button>
    </div>
</div>

<div id="resultsSection" style="display:none">
    <div class="results-header">
        <h3 id="resultsTitle" class="results-title"></h3>
        <div class="pagination-controls">
            <button class="pagination-btn" id="prevBtn" onclick="InspectionsModule.previousPage()">
                <i class="fas fa-chevron-left"></i>
            </button>
            <span id="pageInfo" class="page-info"></span>
            <button class="pagination-btn" id="nextBtn" onclick="InspectionsModule.nextPage()">
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>
    </div>
    
    <div class="table-wrapper">
        <table class="data-table" style="min-width: 900px; width: 100%;">
            <thead>
                <tr>
                    <th style="width: 80px;">Документ</th>
                    <th style="width: 150px;">Discord ID</th>
                    <th style="min-width: 300px;">Результат проверки</th>
                    <th style="width: 180px;">Администратор</th>
                    <th style="width: 180px;">Дата и время</th>
                    <th style="width: 50px;">Действия</th>
                </tr>
            </thead>
            <tbody id="reportsList">
                <tr><td colspan="6" style="text-align:center; padding:3rem; color:var(--text-dim);">Введите данные для поиска</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div id="toast" class="toast toast-success">
    <i class="fas fa-check-circle"></i>
    <span id="toastMessage"></span>
</div>

<div id="toastError" class="toast toast-error">
    <i class="fas fa-exclamation-triangle"></i>
    <span id="toastErrorMsg"></span>
</div>

<div id="editModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:10001; justify-content:center; align-items:center;">
    <div class="modal-content">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
            <h3 style="margin:0;"><i class="fas fa-edit"></i> Редактирование проверки</h3>
            <button onclick="InspectionsModule.closeEditModal()" style="background:none; border:none; color:var(--text-dim); font-size:1.5rem; cursor:pointer;">&times;</button>
        </div>
        <form id="editForm" onsubmit="InspectionsModule.saveEdit(event)">
            <input type="hidden" id="editId">
            <div style="margin-bottom:1rem;">
                <label>Паспорт</label>
                <input type="text" id="editPassport" readonly>
            </div>
            <div style="margin-bottom:1rem;">
                <label>Discord ID</label>
                <input type="text" id="editDiscordId">
            </div>
            <div style="margin-bottom:1rem;">
                <label>Результат проверки</label>
                <textarea id="editResult" rows="6"></textarea>
            </div>
            <div style="display:flex; gap:1rem; justify-content:flex-end;">
                <button type="button" onclick="InspectionsModule.closeEditModal()">Отмена</button>
                <button type="submit" class="btn btn-primary">Сохранить изменения</button>
            </div>
        </form>
    </div>
</div>

<script src="/js/inspections.js"></script>

<%- include('layout', { part: 'footer' }) %>