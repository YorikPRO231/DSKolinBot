<%- include('layout', { part: 'header', title: 'Проверки', currentPage: 'inspections' }) %>

<link rel="stylesheet" href="/css/inspections.css">

<div class="inspections-page-container">
    <div class="page-header">
        <h1>Реестр проверок</h1>
    </div>

    <div class="search-card-panel">
        <div class="search-card-header">
            <h3><i class="fas fa-magnifying-glass search-icon-orange"></i> Поиск по базе данных</h3>
        </div>
        <div class="search-action-row">
            <div class="search-input-field-group">
                <i class="fas fa-fingerprint search-inner-icon"></i>
                <input type="text" id="searchInput" placeholder="Введите номер паспорта или Discord ID игрока...">
            </div>
            <button class="btn btn-primary btn-search-execute" onclick="InspectionsModule.searchRecords()">
                <i class="fas fa-search"></i> Найти записи
            </button>
        </div>
    </div>

    <div id="resultsSection" class="results-fade-section" style="display:none">
        <div class="results-header-management">
            <h3 id="resultsTitle" class="results-headline"></h3>
            
            <div class="pagination-navigation-box">
                <button class="pagination-arrow-control" id="prevBtn" onclick="InspectionsModule.previousPage()">
                    <i class="fas fa-chevron-left"></i>
                </button>
                <span id="pageInfo" class="pagination-current-text"></span>
                <button class="pagination-arrow-control" id="nextBtn" onclick="InspectionsModule.nextPage()">
                    <i class="fas fa-chevron-right"></i>
                </button>
            </div>
        </div>
        
        <div class="table-scrollable-container">
            <table class="data-table inspections-custom-table">
                <thead>
                    <tr>
                        <th style="width: 110px;">Документ</th>
                        <th style="width: 180px;">Discord ID</th>
                        <th>Результат проверки</th>
                        <th style="width: 180px;">Администратор</th>
                        <th style="width: 180px;">Дата и время</th>
                        <th style="width: 60px;" class="text-center">Действия</th>
                    </tr>
                </thead>
                <tbody id="reportsList">
                    <tr>
                        <td colspan="6" class="table-status-message-cell">
                            <i class="fas fa-keyboard status-icon-dim"></i>
                            <p>Введите данные для поиска</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="toast" class="toast-popup-notification toast-popup-success">
    <i class="fas fa-check-circle"></i>
    <span id="toastMessage"></span>
</div>

<div id="toastError" class="toast-popup-notification toast-popup-error">
    <i class="fas fa-exclamation-triangle"></i>
    <span id="toastErrorMsg"></span>
</div>

<div id="editModal" class="modal-blur-overlay">
    <div class="modal-content-box">
        <div class="modal-content-header">
            <h3><i class="fas fa-edit modal-header-icon-accent"></i> Редактирование проверки</h3>
            <button type="button" class="modal-close-trigger" onclick="InspectionsModule.closeEditModal()">&times;</button>
        </div>
        <form id="editForm" onsubmit="InspectionsModule.saveEdit(event)">
            <div class="modal-content-body">
                <input type="hidden" id="editId">
                
                <div class="form-input-element-wrapper">
                    <label for="editPassport">Паспорт (Только чтение)</label>
                    <div class="readonly-input-container">
                        <i class="fas fa-lock"></i>
                        <input type="text" id="editPassport" readonly>
                    </div>
                </div>
                
                <div class="form-input-element-wrapper">
                    <label for="editDiscordId">Discord ID</label>
                    <input type="text" id="editDiscordId" placeholder="Введите Discord ID игрока">
                </div>
                
                <div class="form-input-element-wrapper">
                    <label for="editResult">Результат проверки</label>
                    <textarea id="editResult" rows="6" placeholder="Введите подробный вердикт..."></textarea>
                </div>
            </div>
            
            <div class="modal-content-footer">
                <button type="button" class="btn-modal-dismiss" onclick="InspectionsModule.closeEditModal()">Отмена</button>
                <button type="submit" class="btn btn-primary btn-modal-save">Сохранить изменения</button>
            </div>
        </form>
    </div>
</div>

<script src="/js/inspections.js"></script>

<%- include('layout', { part: 'footer' }) %>