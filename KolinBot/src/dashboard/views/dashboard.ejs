<%
  title = 'Главная';
  currentPage = 'dashboard';
%>

<%- include('layout', { part: 'header', title: title, currentPage: currentPage, user: user }) %>

<style>
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
    }
    .status-online {
        background: rgba(46, 204, 113, 0.15);
        color: #2ecc71;
        border: 1px solid rgba(46, 204, 113, 0.3);
    }
    .status-offline {
        background: rgba(230, 57, 70, 0.15);
        color: #e63946;
        border: 1px solid rgba(230, 57, 70, 0.3);
    }
    .system-info-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1rem;
    }
    .system-info-row {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.85rem;
    }
    .system-info-row:last-child {
        border-bottom: none;
    }
    .system-info-label {
        color: var(--text-dim);
    }
    .system-info-value {
        font-weight: 500;
        font-family: monospace;
    }
    .refresh-btn {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-dim);
        padding: 4px 10px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.7rem;
        transition: all 0.2s;
    }
    .refresh-btn:hover {
        background: var(--bg-main);
        border-color: var(--accent);
        color: var(--accent);
    }
    .env-production {
        background: rgba(46, 204, 113, 0.15);
        color: #2ecc71;
    }
    .env-development {
        background: rgba(241, 196, 15, 0.15);
        color: #f1c40f;
    }
    .stat-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.25rem;
        transition: all 0.2s;
    }
    .stat-card:hover {
        transform: translateY(-2px);
        border-color: var(--accent);
    }
    .efficiency-low {
        color: #e63946;
    }
    .efficiency-medium {
        color: #f1c40f;
    }
    .efficiency-high {
        color: #2ecc71;
    }
    .chart-container {
        position: relative;
        width: 180px;
        height: 180px;
        margin: 0 auto;
    }
    .alerts-table {
        width: 100%;
        font-size: 0.85rem;
    }
    .alerts-table th {
        text-align: left;
        padding: 8px 8px;
        color: var(--text-dim);
        font-weight: 500;
        border-bottom: 1px solid var(--border);
    }
    .alerts-table td {
        padding: 10px 8px;
        border-bottom: 1px solid var(--border);
    }
    .alerts-table tr:last-child td {
        border-bottom: none;
    }
    .badge-bots {
        background: rgba(52, 152, 219, 0.15);
        color: #3498db;
        border: 1px solid rgba(52, 152, 219, 0.3);
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        display: inline-block;
    }
    .badge-cheats {
        background: rgba(230, 57, 70, 0.15);
        color: #e63946;
        border: 1px solid rgba(230, 57, 70, 0.3);
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        display: inline-block;
    }
    .progress-bar {
        height: 8px;
        background: var(--bg-main);
        border-radius: 4px;
        overflow: hidden;
    }
    .progress-fill {
        height: 100%;
        border-radius: 4px;
        transition: width 0.5s ease;
    }
</style>

<div style="margin-bottom: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h1 style="font-size: 1.8rem; letter-spacing: -0.5px;">Панель управления</h1>
            <p style="color: var(--text-dim); margin-top: 0.5rem;">Добро пожаловать, <strong><%= user ? user.username : 'Администратор' %></strong>! Вот сводка активности системы.</p>
        </div>
        <button class="refresh-btn" onclick="refreshHealthData()">
            <i class="fas fa-sync-alt"></i> Обновить
        </button>
    </div>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
    <div class="stat-card">
        <div style="display: flex; align-items: center; justify-content: space-between;">
            <div style="color: var(--text-dim); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Google Формы</div>
            <i class="fas fa-google" style="color: var(--accent); font-size: 1.2rem;"></i>
        </div>
        <div style="font-size: 2.2rem; font-weight: 800; margin-top: 0.5rem;"><%= stats.totalForms %></div>
        <div style="color: var(--text-dim); font-size: 0.7rem; margin-top: 0.5rem;">активных интеграций</div>
    </div>     
    
    <div class="stat-card" style="border-left: 4px solid var(--danger);">
        <div style="display: flex; align-items: center; justify-content: space-between;">
            <div style="color: var(--danger); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Активные алерты</div>
            <i class="fas fa-bell" style="color: var(--danger); font-size: 1.2rem;"></i>
        </div>
        <div style="font-size: 2.2rem; font-weight: 800; margin-top: 0.5rem;"><%= stats.activeAlerts %></div>
        <div style="color: var(--text-dim); font-size: 0.7rem; margin-top: 0.5rem;">требуют внимания</div>
    </div>
    
    <div class="stat-card" style="border-left: 4px solid var(--success);">
        <div style="display: flex; align-items: center; justify-content: space-between;">
            <div style="color: var(--success); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Всего проверок</div>
            <i class="fas fa-clipboard-list" style="color: var(--success); font-size: 1.2rem;"></i>
        </div>
        <div style="font-size: 2.2rem; font-weight: 800; margin-top: 0.5rem;"><%= stats.inspections || 0 %></div>
        <div style="color: var(--text-dim); font-size: 0.7rem; margin-top: 0.5rem;">выполнено за всё время</div>
    </div>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
    <div class="stat-card">
        <div style="display: flex; align-items: center; justify-content: space-between;">
            <div style="color: var(--text-dim); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Сливов склада</div>
            <i class="fas fa-boxes" style="color: var(--accent); font-size: 1.2rem;"></i>
        </div>
        <div style="font-size: 2.2rem; font-weight: 800; margin-top: 0.5rem;"><%= stats.warehouseItems || 0 %></div>
        <div style="color: var(--text-dim); font-size: 0.7rem; margin-top: 0.5rem;">в системе</div>
    </div>
    
    <div class="stat-card">
        <div style="display: flex; align-items: center; justify-content: space-between;">
            <div style="color: var(--text-dim); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Нашивки</div>
            <i class="fas fa-tags" style="color: var(--accent); font-size: 1.2rem;"></i>
        </div>
        <div style="font-size: 2.2rem; font-weight: 800; margin-top: 0.5rem;"><%= stats.totalPatches || 0 %></div>
        <div style="color: var(--text-dim); font-size: 0.7rem; margin-top: 0.5rem;">в системе</div>
    </div>
    
    <div class="stat-card">
        <div style="display: flex; align-items: center; justify-content: space-between;">
            <div style="color: var(--text-dim); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Эффективность</div>
            <i class="fas fa-chart-line" style="color: var(--accent); font-size: 1.2rem;"></i>
        </div>
        <div style="font-size: 2.2rem; font-weight: 800; margin-top: 0.5rem;">
            <% 
                const activeAlerts = stats.activeAlerts || 0;
                const inspections = stats.inspections || 0;
                let efficiency = 0;
                let efficiencyClass = '';
                
                if (inspections > 0) {
                    efficiency = Math.min(100, Math.round((activeAlerts / inspections) * 100));
                } else if (activeAlerts > 0) {
                    efficiency = 100;
                }
                
                if (efficiency >= 70) {
                    efficiencyClass = 'efficiency-high';
                } else if (efficiency >= 40) {
                    efficiencyClass = 'efficiency-medium';
                } else {
                    efficiencyClass = 'efficiency-low';
                }
            %>
            <span class="<%= efficiencyClass %>"><%= efficiency %>%</span>
        </div>
        <div style="color: var(--text-dim); font-size: 0.7rem; margin-top: 0.5rem;">алартов к проверкам</div>
    </div>
</div>

<div class="system-info-card" style="margin-bottom: 2rem;">
    <h3 style="margin-bottom: 1rem; font-size: 1rem;">
        <i class="fas fa-server" style="color: var(--accent); margin-right: 8px;"></i> 
        Статус системы
    </h3>
    <div id="healthData">
        <div style="text-align: center; padding: 1rem;">
            <i class="fas fa-spinner fa-spin"></i> Загрузка данных...
        </div>
    </div>
</div>

<% if (stats.activeAlerts > 0) { %>
<div class="card" style="margin-bottom: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <h3 style="font-size: 1rem;">
            <i class="fas fa-chart-pie" style="color: var(--accent); margin-right: 8px;"></i> 
            Статистика алартов
        </h3>
        <a href="/dashboard/security" style="color: var(--accent); font-size: 0.8rem; text-decoration: none;">Все аларты →</a>
    </div>
    
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: center;">
        <div class="chart-container">
            <canvas id="alertsChart" width="180" height="180" style="width: 180px; height: 180px;"></canvas>
            <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center;">
                <div style="font-size: 2rem; font-weight: 800;"><%= stats.activeAlerts %></div>
                <div style="font-size: 0.7rem; color: var(--text-dim);">всего</div>
            </div>
        </div>
        
        <div>
            <div style="margin-bottom: 1rem;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 0.25rem;">
                    <span style="font-size: 0.75rem;">Боты</span>
                    <span style="font-size: 0.75rem; font-weight: 600;" id="botsCount">-</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" id="botsProgress" style="width: 0%; background: #3498db;"></div>
                </div>
            </div>
            <div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 0.25rem;">
                    <span style="font-size: 0.75rem;">Читы</span>
                    <span style="font-size: 0.75rem; font-weight: 600;" id="cheatsCount">-</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" id="cheatsProgress" style="width: 0%; background: #e63946;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
        <h3 style="font-size: 1rem;">
            <i class="fas fa-list" style="color: var(--accent); margin-right: 8px;"></i> 
            Последние аларты
        </h3>
        <a href="/dashboard/security" style="color: var(--accent); font-size: 0.8rem; text-decoration: none;">Все →</a>
    </div>
    <div style="overflow-x: auto;">
        <table class="alerts-table">
            <thead>
                <tr>
                    <th>Статик</th>
                    <th>Тип</th>
                    <th>Причина</th>
                    <th style="text-align: center;">Кол-во</th>
                    <th>Дата</th>
                </tr>
            </thead>
            <tbody id="latestAlerts">
                <tr><td colspan="5" style="text-align: center; padding: 2rem;"><i class="fas fa-spinner fa-spin"></i> Загрузка...</td</tr>
            </tbody>
        </table>
    </div>
</div>
<% } %>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
let alertsChart = null;

async function refreshHealthData() {
    const container = document.getElementById('healthData');
    if (!container) return;
    
    try {
        const response = await fetch('/health');
        const data = await response.json();
        
        const formatUptime = (seconds) => {
            const days = Math.floor(seconds / 86400);
            const hours = Math.floor((seconds % 86400) / 3600);
            const minutes = Math.floor((seconds % 3600) / 60);
            const secs = Math.floor(seconds % 60);
            
            const parts = [];
            if (days > 0) parts.push(`${days}д`);
            if (hours > 0) parts.push(`${hours}ч`);
            if (minutes > 0) parts.push(`${minutes}м`);
            parts.push(`${secs}с`);
            return parts.join(' ');
        };
        
        const discordStatus = data.discordReady ? 'online' : 'offline';
        const discordStatusText = data.discordReady ? 'Подключен' : 'Отключен';
        const discordStatusClass = data.discordReady ? 'status-online' : 'status-offline';
        
        const envClass = data.environment === 'production' ? 'env-production' : 'env-development';
        const envText = data.environment === 'production' ? 'Production' : 'Development';
        
        const healthHtml = `
            <div class="system-info-row">
                <span class="system-info-label"><i class="fas fa-microchip"></i> Статус сервера</span>
                <span class="system-info-value"><span class="status-badge status-online"><i class="fas fa-circle" style="font-size: 0.5rem;"></i> Работает</span></span>
            </div>
            <div class="system-info-row">
                <span class="system-info-label"><i class="fab fa-discord"></i> Discord бот</span>
                <span class="system-info-value"><span class="status-badge ${discordStatusClass}"><i class="fas fa-circle" style="font-size: 0.5rem;"></i> ${discordStatusText}</span></span>
            </div>
            <div class="system-info-row">
                <span class="system-info-label"><i class="fas fa-link"></i> Активных форм</span>
                <span class="system-info-value"><strong>${data.bindings || 0}</strong></span>
            </div>
            <div class="system-info-row">
                <span class="system-info-label"><i class="fas fa-clock"></i> Аптайм</span>
                <span class="system-info-value">${formatUptime(data.uptime || 0)}</span>
            </div>
            <div class="system-info-row">
                <span class="system-info-label"><i class="fas fa-tag"></i> Окружение</span>
                <span class="system-info-value"><span class="status-badge ${envClass}">${envText}</span></span>
            </div>
        `;
        
        if (container.innerHTML !== healthHtml) {
            container.innerHTML = healthHtml;
        }
    } catch (error) {
        console.error('Ошибка загрузки health:', error);
        const errorHtml = `
            <div class="system-info-row">
                <span class="system-info-label">Статус</span>
                <span class="system-info-value"><span class="status-badge status-offline"><i class="fas fa-exclamation-triangle"></i> Ошибка загрузки</span></span>
            </div>
            <div class="system-info-row">
                <span class="system-info-label">Discord бот</span>
                <span class="system-info-value"><span class="status-badge status-offline"><i class="fas fa-circle" style="font-size: 0.5rem;"></i> Неизвестно</span></span>
            </div>
        `;
        if (container.innerHTML !== errorHtml) {
            container.innerHTML = errorHtml;
        }
    }
}

async function loadLatestAlerts() {
    try {
        const response = await fetch('/api/security/alerts?limit=10');
        const data = await response.json();
        const tbody = document.getElementById('latestAlerts');
        
        if (!tbody) return;
        
        if (data.success && data.alerts && data.alerts.length > 0) {
            let botsCount = 0;
            let cheatsCount = 0;
            let html = '';
            
            const alertsToShow = data.alerts.slice(0, 10);
            
            for (const alert of alertsToShow) {
                const typeClass = alert.type === 'Bots' ? 'badge-bots' : 'badge-cheats';
                const typeText = alert.type === 'Bots' ? 'Боты' : 'Читы';
                const reason = alert.reason || '';
                const shortReason = reason.length > 40 ? reason.substring(0, 40) + '...' : reason;
                
                if (alert.type === 'Bots') botsCount++;
                else cheatsCount++;
                
                html += `
                    <tr>
                        <td><strong>${escapeHtml(alert.passport)}</strong></td>
                        <td><span class="${typeClass}">${typeText}</span></td>
                        <td title="${escapeHtml(reason)}">${escapeHtml(shortReason)}</td>
                        <td style="text-align: center;">${alert.count || 1}</td>
                        <td><small>${new Date(alert.created_at).toLocaleString()}</small></td>
                    </tr>
                `;
            }
            
            if (tbody.innerHTML !== html) {
                tbody.innerHTML = html;
            }
            
            const total = botsCount + cheatsCount;
            if (total > 0) {
                const botsCountEl = document.getElementById('botsCount');
                const cheatsCountEl = document.getElementById('cheatsCount');
                const botsProgressEl = document.getElementById('botsProgress');
                const cheatsProgressEl = document.getElementById('cheatsProgress');
                
                if (botsCountEl && botsCountEl.innerText !== botsCount.toString()) {
                    botsCountEl.innerText = botsCount;
                }
                if (cheatsCountEl && cheatsCountEl.innerText !== cheatsCount.toString()) {
                    cheatsCountEl.innerText = cheatsCount;
                }
                
                const botsPercent = (botsCount / total * 100) + '%';
                const cheatsPercent = (cheatsCount / total * 100) + '%';
                
                if (botsProgressEl && botsProgressEl.style.width !== botsPercent) {
                    botsProgressEl.style.width = botsPercent;
                }
                if (cheatsProgressEl && cheatsProgressEl.style.width !== cheatsPercent) {
                    cheatsProgressEl.style.width = cheatsPercent;
                }
            }
            
            if (alertsChart) {
                if (alertsChart.data.datasets[0].data[0] !== botsCount || alertsChart.data.datasets[0].data[1] !== cheatsCount) {
                    alertsChart.data.datasets[0].data = [botsCount, cheatsCount];
                    alertsChart.update();
                }
            } else {
                const ctx = document.getElementById('alertsChart');
                if (ctx) {
                    alertsChart = new Chart(ctx, {
                        type: 'doughnut',
                        data: {
                            labels: ['Боты', 'Читы'],
                            datasets: [{
                                data: [botsCount, cheatsCount],
                                backgroundColor: ['#3498db', '#e63946'],
                                borderWidth: 0,
                                hoverOffset: 5
                            }]
                        },
                        options: {
                            cutout: '65%',
                            responsive: true,
                            maintainAspectRatio: true,
                            plugins: {
                                legend: {
                                    display: false
                                },
                                tooltip: {
                                    callbacks: {
                                        label: function(context) {
                                            const label = context.label || '';
                                            const value = context.raw || 0;
                                            const total = botsCount + cheatsCount;
                                            const percent = total > 0 ? Math.round((value / total) * 100) : 0;
                                            return `${label}: ${value} (${percent}%)`;
                                        }
                                    }
                                }
                            }
                        }
                    });
                }
            }
        } else {
            const emptyHtml = '<tr><td colspan="5" style="text-align: center;">Нет активных алартов</td></tr>';
            if (tbody.innerHTML !== emptyHtml) {
                tbody.innerHTML = emptyHtml;
            }
        }
    } catch (error) {
        console.error('Ошибка загрузки алартов:', error);
        const errorHtml = '<tr><td colspan="5" style="text-align: center;">Ошибка загрузки</td></tr>';
        const tbody = document.getElementById('latestAlerts');
        if (tbody && tbody.innerHTML !== errorHtml) {
            tbody.innerHTML = errorHtml;
        }
    }
}

function escapeHtml(text) {
    if (!text) return '';
    return String(text).replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
    });
}

refreshHealthData();
setInterval(refreshHealthData, 30000);

loadLatestAlerts();
setInterval(loadLatestAlerts, 30000);
</script>

<%- include('layout', { part: 'footer' }) %>