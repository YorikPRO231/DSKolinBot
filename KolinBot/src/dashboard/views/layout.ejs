<% if (part === 'header') { %>
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png">
    <link rel="manifest" href="/site.webmanifest">
    <title><%= title %> — Blackberry Admin</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <% 
        const hasP = (perm) => permissions && permissions.includes(perm); 
        
        const safeRender = (str) => {
            if (!str) return '';
            return String(str).replace(/[&<>"']/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' }[m]));
        }
    %>
    <nav class="navbar">
        <div class="nav-container">
            <a href="/dashboard" class="nav-brand"><span>BLACK</span>BERRY</a>
            <div class="nav-links">
                <a href="/dashboard" class="nav-link <%= currentPage === 'dashboard' ? 'active' : '' %>">
                    Дашборд
                </a>
                
                <% if (hasP('manage_forms')) { %>
                    <a href="/dashboard/forms" class="nav-link <%= currentPage === 'forms' ? 'active' : '' %>">
                       Формы
                    </a>
                <% } %>
                
                <% if (hasP('view_security')) { %>
                    <a href="/dashboard/security" class="nav-link <%= currentPage === 'security' ? 'active' : '' %>">
                        Security
                    </a>
                <% } %>
                
                <% if (hasP('view_inspections')) { %>
                    <a href="/dashboard/inspections" class="nav-link <%= currentPage === 'inspections' ? 'active' : '' %>">
                        Проверки
                    </a>
                <% } %>
                
                <% if (hasP('view_admin_logs')) { %>
                    <a href="/dashboard/admin-logs" class="nav-link <%= currentPage === 'admin-logs' ? 'active' : '' %>">
                       Админ-логи
                    </a>
                <% } %>
                
                <% if (hasP('manage_roles')) { %>
                    <a href="/admin/permissions" class="nav-link <%= currentPage === 'permissions' ? 'active' : '' %>">
                        Права
                    </a>
                <% } %>
                
                <% if (hasP('view_logs_systeminformer')) { %>
    <a href="/upload" class="nav-link <%= currentPage === 'upload' ? 'active' : '' %>">
       </i> Выгрузка
    </a>
<% } %>
<% if (hasP('edit_settings')) { %>
    <a href="/admin/settings" class="nav-link <%= currentPage === 'settings' ? 'active' : '' %>">
        Настройки
    </a>
<% } %>
            </div>
            <div style="display:flex; align-items:center; gap:15px;">
                <span style="font-size:0.85rem; font-weight:600;">
                    <%= user ? safeRender(user.username) : 'Admin' %>
                </span>
                <a href="/logout" style="color:var(--danger);"><i class="fas fa-power-off"></i></a>
            </div>
        </div>
    </nav>
    <main class="container">
<% } else if (part === 'footer') { %>
    </main>
<div id="globalToast" class="global-toast">
    <i id="globalToastIcon" class="fas fa-check-circle"></i>
    <span id="globalToastMessage" class="global-toast-message"></span>
</div>
    
    <script src="/js/main.js"></script>
</body>
</html>
<% } %>