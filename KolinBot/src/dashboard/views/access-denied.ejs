<%
  title = 'Access Denied';
  currentPage = 'access-denied';
%>

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png">
    <link rel="manifest" href="/site.webmanifest">
    <title>Access Denied — Blackberry Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: linear-gradient(135deg, #0a0c10 0%, #14181c 100%);
            color: #e1e1e1;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        
        .container {
            width: 100%;
            max-width: 550px;
            padding: 20px;
        }
        
        .card {
            background: #15181b;
            border: 1px solid #2d3238;
            border-radius: 24px;
            padding: 2rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        
        .lock-icon {
            font-size: 3rem;
            color: #ff4d4d;
            text-align: center;
            margin-bottom: 1rem;
        }
        
        h1 {
            font-size: 1.8rem;
            font-weight: 700;
            text-align: center;
            margin-bottom: 0.5rem;
        }
        
        .subtitle {
            color: #9ba1a6;
            text-align: center;
            font-size: 0.9rem;
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #2d3238;
        }
        
        .info-box {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 12px;
            padding: 1rem;
            margin-bottom: 1rem;
        }
        
        .info-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            color: #9ba1a6;
            margin-bottom: 0.75rem;
            letter-spacing: 0.5px;
        }
        
        .roles-list {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }
        
        .role-tag {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid #2d3238;
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 0.75rem;
        }
        
        .role-name {
            color: #FF6B00;
            font-weight: 500;
        }
        
        .role-id {
            color: #9ba1a6;
            font-size: 0.65rem;
            font-family: monospace;
            margin-left: 6px;
        }
        
        .logout-btn {
            display: block;
            width: 100%;
            padding: 12px;
            background: #FF6B00;
            color: white;
            text-decoration: none;
            border-radius: 10px;
            font-weight: 600;
            text-align: center;
            margin-top: 1.5rem;
            transition: all 0.2s;
        }
        
        .logout-btn:hover {
            background: #e66000;
            transform: translateY(-1px);
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <div class="lock-icon">
                <i class="fas fa-lock"></i>
            </div>
            
            <h1>Доступ запрещён</h1>
            <div class="subtitle">
                У вас нет необходимых прав для доступа к панели управления
            </div>
            
            <div class="info-box">
                <div class="info-label">Требуемые роли</div>
                <div class="roles-list">
                    <% if (requiredRoles && requiredRoles.length > 0) { %>
                        <% requiredRoles.forEach(function(roleId) { %>
                            <div class="role-tag">
                                <span class="role-id"><%= roleId %></span>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="role-tag">Роли не настроены</div>
                    <% } %>
                </div>
            </div>
            
            <div class="info-box">
                <div class="info-label">Ваши роли</div>
                <div class="roles-list">
                    <% if (userRoleNames && userRoleNames.length > 0) { %>
                        <% for (var i = 0; i < userRoleNames.length; i++) { %>
                            <div class="role-tag">
                                <span class="role-name"><%= userRoleNames[i] %></span>
                                <span class="role-id">(<%= userRoleIds[i] %>)</span>
                            </div>
                        <% } %>
                    <% } else { %>
                        <div class="role-tag">Роли не найдены</div>
                    <% } %>
                </div>
            </div>
            
            <a href="/logout" class="logout-btn">
                <i class="fas fa-sign-out-alt"></i> Выйти
            </a>
        </div>
    </div>
</body>
</html>