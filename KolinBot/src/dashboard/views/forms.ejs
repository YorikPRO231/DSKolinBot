<%
  title = 'Формы';
  currentPage = 'forms';
%>

<%- include('layout', { part: 'header', title: title, currentPage: currentPage, user: user }) %>

<link rel="stylesheet" href="/css/forms.css">

<div class="page-header-forms">
    <h1><i class="fas fa-link" style="color: var(--accent); margin-right: 12px;"></i>Интеграции форм</h1>
    <button class="btn btn-primary" onclick="FormsModule.showModal('addFormModal')">
        <i class="fas fa-plus"></i> Добавить интеграцию
    </button>
</div>

<div class="card" style="padding:0; overflow-x: auto;">
    <table class="data-table" style="min-width: 1000px; width: 100%;">
        <thead>
            <tr>
                <th style="width: 18%;">ID формы</th>
                <th style="width: 20%;">Сервер</th>
                <th style="width: 20%;">Канал</th>
                <th style="width: 15%;">Название</th>
                <th style="width: 20%;">Роли для пинга</th>
                <th style="width: 7%;">Действия</th>
            </tr>
        </thead>
        <tbody id="formsList">
            <tr><td colspan="6" class="empty-state"><i class="fas fa-spinner fa-spin"></i><p>Загрузка данных...</p></td</tr>
        </tbody>
    </table>
</div>

<div id="addFormModal" class="modal">
    <div class="modal-content">
        <h3 style="margin-bottom:1.5rem; display: flex; align-items: center; gap: 8px;">
            <i class="fas fa-plus-circle" style="color: var(--accent);"></i>
            Новая интеграция
        </h3>
        <form id="addForm">
            <div class="form-group">
                <label><i class="fas fa-id-card"></i> ID формы</label>
                <input type="text" name="formId" placeholder="https://docs.google.com/forms/d/.../viewform" required>
                <small>ID из URL Google Forms</small>
            </div>
            <div class="form-group">
                <label><i class="fas fa-hashtag"></i> Discord Channel ID</label>
                <input type="text" name="channelId" placeholder="Включите режим разработчика в Discord" required>
                <small>ID канала, куда будут отправляться ответы</small>
            </div>
            <div class="form-group">
                <label><i class="fas fa-server"></i> Discord Guild ID</label>
                <input type="text" name="guildId" placeholder="ID сервера Discord" required>
                <small>ID сервера, на котором находится канал</small>
            </div>
            <div class="form-group">
                <label><i class="fas fa-tag"></i> Название формы</label>
                <input type="text" name="formName" placeholder="Например: Заявка на бан">
                <small>Опционально, для удобства</small>
            </div>
            <div class="form-group">
                <label><i class="fas fa-at"></i> ID роли для пинга</label>
                <input type="text" name="pingRoleId" placeholder="ID роли">
                <small>Роль, которая будет упоминаться при новом ответе</small>
            </div>
            <div class="form-group">
                <label><i class="fas fa-at"></i> ID второй роли</label>
                <input type="text" name="pingRoleId2" placeholder="ID роли">
                <small>Опционально, вторая роль для упоминания</small>
            </div>
            <div class="modal-buttons">
                <button type="button" onclick="FormsModule.closeModal('addFormModal')">Отмена</button>
                <button type="submit" class="btn btn-primary">Создать интеграцию</button>
            </div>
        </form>
    </div>
</div>

<div id="confirmDeleteModal" class="modal">
    <div class="modal-content">
        <i class="fas fa-exclamation-triangle" style="font-size: 3rem; color: var(--danger); margin-bottom: 1rem;"></i>
        <h3 style="margin-bottom: 0.5rem;">Удаление интеграции</h3>
        <p id="deleteFormName" style="color: var(--text-dim); margin-bottom: 1.5rem;">Вы уверены, что хотите удалить эту интеграцию?</p>
        <div class="confirm-buttons">
            <button id="deleteCancelBtn" class="btn-cancel">Отмена</button>
            <button id="deleteConfirmBtn" class="btn-danger">Удалить</button>
        </div>
    </div>
</div>

<div id="notificationModal" class="modal">
    <div class="modal-content">
        <i id="notificationIcon" class="fas fa-check-circle" style="font-size: 3rem; margin-bottom: 1rem;"></i>
        <h3 id="notificationTitle" style="margin-bottom: 0.5rem;">Успех</h3>
        <p id="notificationMessage" style="color: var(--text-dim); margin-bottom: 1.5rem;">Действие выполнено</p>
        <button class="btn btn-primary" onclick="FormsModule.closeModal('notificationModal')">Закрыть</button>
    </div>
</div>

<script src="/js/forms.js"></script>

<%- include('layout', { part: 'footer' }) %>