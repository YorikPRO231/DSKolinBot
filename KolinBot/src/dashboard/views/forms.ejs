<%
  title = 'Формы';
  currentPage = 'forms';
%>

<%- include('layout', { part: 'header', title: title, currentPage: currentPage, user: user }) %>

<link rel="stylesheet" href="/css/forms.css">

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 2rem;">
    <h1>Интеграции форм</h1>
    <button class="btn btn-primary" onclick="FormsModule.showModal('addFormModal')">
        <i class="fas fa-plus"></i> Добавить связь
    </button>
</div>

<div class="card" style="padding:0; overflow-x: auto;">
    <table class="data-table" style="min-width: 900px;">
        <thead>
            <tr>
                <th>ID Формы</th>
                <th>Сервер</th>
                <th>Канал</th>
                <th>Название формы</th>
                <th>Роль для пинга</th>
                <th style="width: 80px;">Действия</th>
            </tr>
        </thead>
        <tbody id="formsList">
            <tr><td colspan="6" style="text-align:center; padding:3rem; color:var(--text-dim);">Загрузка данных...</td></tr>
        </tbody>
    </table>
</div>

<div id="addFormModal" class="modal">
    <div class="modal-content">
        <h3 style="margin-bottom:1.5rem;">Новая интеграция</h3>
        <form id="addForm">
            <input type="text" name="formId" placeholder="ID формы (из URL Google Forms)" required>
            <input type="text" name="channelId" placeholder="Discord Channel ID" required>
            <input type="text" name="guildId" placeholder="Discord Guild ID (сервер)" required>
            <input type="text" name="formName" placeholder="Название формы (опционально)">
            <input type="text" name="pingRoleId" placeholder="ID роли для пинга (опционально)">
            <input type="text" name="pingRoleId2" placeholder="ID второй роли для пинга (опционально)">
            <div style="display:flex; gap:10px; justify-content:flex-end;">
                <button type="button" onclick="FormsModule.closeModal('addFormModal')">Отмена</button>
                <button type="submit" class="btn btn-primary">Создать</button>
            </div>
        </form>
    </div>
</div>

<div id="confirmDeleteModal" class="modal">
    <div class="modal-content">
        <i class="fas fa-exclamation-triangle" style="font-size: 3rem; color: var(--danger); margin-bottom: 1rem;"></i>
        <h3 style="margin-bottom: 0.5rem;">Удаление формы</h3>
        <p id="deleteFormName" style="color: var(--text-dim); margin-bottom: 1.5rem;">Вы уверены, что хотите удалить эту интеграцию?</p>
        <div style="display: flex; gap: 10px; justify-content: center;">
            <button id="deleteCancelBtn">Отмена</button>
            <button id="deleteConfirmBtn" class="btn" style="background: var(--danger);">Удалить</button>
        </div>
    </div>
</div>

<div id="notificationModal" class="modal">
    <div class="modal-content">
        <i id="notificationIcon" class="fas fa-check-circle" style="font-size: 3rem; margin-bottom: 1rem;"></i>
        <h3 id="notificationTitle" style="margin-bottom: 0.5rem;">Успех</h3>
        <p id="notificationMessage" style="color: var(--text-dim); margin-bottom: 1.5rem;">Действие выполнено</p>
        <button class="btn btn-primary" onclick="FormsModule.closeModal('notificationModal')">Закрыть</button>
    </div>
</div>

<script src="/js/forms.js"></script>

<%- include('layout', { part: 'footer' }) %>