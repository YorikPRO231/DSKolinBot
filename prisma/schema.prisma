generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  discordId String   @id @map("discord_id")
  surname   String
  security  String?   @default("no")
  
  inspectionReports InspectionReport[] @relation("AdminInspections")
  securityAlerts    SecurityAlert[]    @relation("AdminAlerts")
  warehouseDrains   WarehouseDrain[]   @relation("AdminDrains")
  warehouseDrainsV2 WarehouseDrainV2[] @relation("AdminDrainsV2")
  
  @@map("admins")
}

model InspectionReport {
  id         Int      @id @default(autoincrement())
  passport   String
  discordId  String?  @map("discord_id")
  result     String
  adminId    String   @map("admin_id")
  adminName  String?  @map("admin_name")
  createdAt  DateTime @default(now()) @map("created_at")
  
  admin Admin @relation("AdminInspections", fields: [adminId], references: [discordId])
  
  @@index([passport])
  @@index([createdAt(sort: Desc)])
  @@map("inspection_reports")
}

model StatePatch {
  id         Int     @id @default(autoincrement())
  passport   Int     @unique
  username   String
  discordId  String  @map("discord_id")
  faction    String
  patch      String
  createdAt  DateTime @default(now()) @map("created_at")
  history    String   @default("[]")
  
  @@map("state_patches")
}

model Infiltration {
  id               Int    @id @default(autoincrement())
  rank             Int
  faction          String
  detectiveFaction String @map("detectivefaction")
  detectiveId      String @unique @map("detectiveid")
  newNickname      String @map("newnickname")
  oldNickname      String @map("oldnickname")
  passport         String
  
  @@map("infiltrations")
}

model Role {
  roleId        String   @id @map("role_id")
  roleName      String   @map("role_name")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")
  
  permissions   RolePermission[]
  userRoles     UserRole[]
  
  @@map("roles")
}

model Permission {
  permissionKey   String   @id @map("permission_key")
  permissionName  String   @map("permission_name")
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")
  
  rolePermissions  RolePermission[]
  userPermissions  UserPermission[]
  
  @@map("permissions")
}

model RolePermission {
  roleId        String   @map("role_id")
  permissionKey String   @map("permission_key")
  grantedBy     String?  @map("granted_by")
  grantedAt     DateTime @default(now()) @map("granted_at")
  
  role         Role       @relation(fields: [roleId], references: [roleId], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionKey], references: [permissionKey], onDelete: Cascade)
  
  @@id([roleId, permissionKey])
  @@map("role_permissions")
}

model UserPermission {
  userId        String    @map("user_id")
  permissionKey String    @map("permission_key")
  isGranted     Boolean   @default(true) @map("is_granted")
  grantedBy     String?   @map("granted_by")
  grantedAt     DateTime  @default(now()) @map("granted_at")
  expiresAt     DateTime? @map("expires_at")
  reason        String?
  
  permission Permission @relation(fields: [permissionKey], references: [permissionKey], onDelete: Cascade)
  
  @@id([userId, permissionKey])
  @@map("user_permissions")
}

model UserPermissionCache {
  userId      String   @id @map("user_id")
  permissions String
  updatedAt   DateTime @default(now()) @map("updated_at")
  
  @@map("user_permissions_cache")
}

model UserRole {
  userId      String   @map("user_id")
  roleId      String   @map("role_id")
  assignedBy  String?  @map("assigned_by")
  assignedAt  DateTime @default(now()) @map("assigned_at")
  
  role Role @relation(fields: [roleId], references: [roleId], onDelete: Cascade)
  
  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Transfer {
  id                Int      @id @default(autoincrement())
  currentRank       Int      @map("current_rank")
  current           String
  destination       String
  passport          String   @unique
  userId            String   @map("user_id")
  nickname          String
  currentApprove    String   @map("current_approve")
  destinationApprove String   @map("destination_approve")
  msgId             String   @map("msg_id")
  
  @@map("transfers")
}

model SecurityAlert {
  id         Int      @id @default(autoincrement())
  passport   String
  type       String   @db.Text
  count      Int      @default(1)
  authorId   String   @map("author_id")
  reason     String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  
  author Admin @relation("AdminAlerts", fields: [authorId], references: [discordId])
  
  @@map("bot_cheat_reports")
}

model SecurityLog {
  id              Int      @id @default(autoincrement())
  username        String
  suspectedAction String   @map("suspected_action")
  checkedAt       DateTime @default(now()) @map("checked_at")
  adminId         String   @map("admin_id")
  checkResults    String   @map("check_results")
  
  @@map("security_logs")
}

model WarehouseDrain {
  id         Int      @id @default(autoincrement())
  pasport    String
  admId      String   @map("adm_id")
  punishment String
  items      String
  logFile    Bytes    @map("log_file")
  duration   String
  createdAt  DateTime @default(now()) @map("created_at")
  
  admin Admin @relation("AdminDrains", fields: [admId], references: [discordId])
  
  @@index([pasport])
  @@index([createdAt(sort: Desc)])
  @@map("warehouse_drain")
}

model WarehouseDrainV2 {
  id         Int      @id @default(autoincrement())
  passport   String
  adminId    String   @map("adminId")
  punishment String
  reportData String   @map("report_data")
  duration   String
  createdAt  DateTime @default(now()) @map("created_at")
  
  admin Admin @relation("AdminDrainsV2", fields: [adminId], references: [discordId])
  
  @@map("warehouse_drain_v2")
}