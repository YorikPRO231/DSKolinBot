{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "rootDir": "./KolinBot/src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "typeRoots": [
      "./KolinBot/src/types",
      "./node_modules/@types"
    ]
  },
  "include": ["KolinBot/src/**/*.ts", "KolinBot/init-permissions.ts"],
  "exclude": ["node_modules", "dist"]
}