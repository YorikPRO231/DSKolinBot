<%- include('layout', { part: 'header', title: 'Архив Системных Логов', currentPage: 'admin-logs', user: user }) %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" href="/css/admin-logs.css">

<div class="admin-logs-wrapper">
    <div class="progress-bar-container" id="progressBarContainer">
        <div class="progress-bar" id="progressBar"></div>
    </div>

    <div class="search-panel">
        <div class="search-row">
            <div class="search-input-container">
                <input type="text" id="searchInput" class="search-input-field" placeholder="Поиск по ID, имени, событию...">
            </div>
          
            <div class="custom-select-container" id="categorySelectContainer">
                <div class="custom-select-trigger">
                    <span class="custom-select-text">Все категории</span>
                    <span class="custom-select-arrow"></span>
                </div>
                <div class="custom-options-dropdown">
                    <div class="custom-option selected" data-value="all">Все категории</div>
                    <div class="custom-option" data-value="message_delete">Удаление сообщений</div>
                    <div class="custom-option" data-value="message_edit">Редактирование сообщений</div>
                    <div class="custom-option" data-value="voice">Голосовые каналы</div>
                </div>
                <select id="categoryFilter" style="display: none;">
                    <option value="all" selected>Все категории</option>
                    <option value="message_delete">Удаление сообщений</option>
                    <option value="message_edit">Редактирование сообщений</option>
                    <option value="voice">Голосовые каналы</option>
                </select>
            </div>
            
            <div class="action-buttons">
                <button class="btn-primary" onclick="performSearch(1)">Найти</button>
                <button class="btn-secondary" onclick="resetFilters()">Сбросить</button>
            </div>
        </div>

        <div class="date-filters">
            <div class="date-filter-group">
                <label>С даты</label>
                <div class="date-input-wrapper">
                    <input type="text" id="dateFrom" class="custom-date-input" placeholder="Выберите дату" readonly>
                </div>
            </div>
            <div class="date-filter-group">
                <label>По дату</label>
                <div class="date-input-wrapper">
                    <input type="text" id="dateTo" class="custom-date-input" placeholder="Выберите дату" readonly>
                </div>
            </div>
        </div>

        <div class="search-stats" id="searchStats" style="display: none;">
            <div class="stats-info">
                <div class="stats-item">
                    <span>Найдено записей:</span>
                    <span class="stats-number" id="totalCount">0</span>
                </div>
                <div class="stats-item">
                    <span>Время выполнения:</span>
                    <span class="stats-number" id="queryTime">0</span>
                    <span>мс</span>
                </div>
            </div>
        </div>
    </div>

    <div class="logs-table-container">
        <table class="logs-table">
            <thead>
                <tr>
                    <th style="width: 170px;">Время</th>
                    <th style="width: 200px;">Тип</th>
                    <th style="width: 180px;">ID Субъекта</th>
                    <th>Описание</th>
                </tr>
            </thead>
            <tbody id="logsTableBody">
                <tr><td colspan="4" style="text-align: center; padding: 50px; color: var(--log-text-dim);">Введите запрос для начала поиска</td></tr>
            </tbody>
        </table>
    </div>

    <div class="pagination" id="pagination" style="display: none;">
        <button class="page-btn" id="prevPageBtn" onclick="changePage(-1)">← Назад</button>
        <span id="pageInfo" style="padding: 8px 20px; color: var(--log-text-dim);">Страница 1</span>
        <button class="page-btn" id="nextPageBtn" onclick="changePage(1)">Вперед →</button>
    </div>
</div>

<div id="logModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Детали события</h3>
            <button class="modal-close" id="closeModalBtn" aria-label="Закрыть">×</button>
        </div>
        <div class="modal-body">
            <div id="logDetailContent" class="log-details"></div>
        </div>
        <div class="modal-footer">
            <button class="btn-secondary" id="closeModalFooterBtn">Закрыть</button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/ru.js"></script>
<script src="/js/admin-logs.js"></script>

<%- include('layout', { part: 'footer' }) %>