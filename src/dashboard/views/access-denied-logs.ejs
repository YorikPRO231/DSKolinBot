<%
  title = title || 'Access Denied';
  currentPage = 'access-denied';
%>

<%- include('layout', { part: 'header', title: title, currentPage: currentPage, user: user }) %>

<div class="container" style="display: flex; justify-content: center; align-items: center; min-height: 60vh;">
    <div class="card" style="max-width: 500px; text-align: center; padding: 3rem;">
        <i class="fas fa-lock" style="font-size: 4rem; color: var(--danger); margin-bottom: 1.5rem;"></i>
        <h1 style="color: var(--danger); margin-bottom: 1rem;">Доступ запрещен </h1>
        <p style="color: var(--text-dim); margin-bottom: 2rem;">
            <%= message || 'У вас нет доступа к данным логам' %>
        </p>
        <a href="/dashboard" class="btn btn-primary">
            <i class="fas fa-arrow-left"></i> Вернуться к панели управления
        </a>
    </div>
</div>

<%- include('layout', { part: 'footer' }) %>