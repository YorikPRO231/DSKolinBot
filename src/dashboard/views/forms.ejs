<%
  title = 'Формы';
  currentPage = 'forms';
%>

<%- include('layout', { part: 'header', title: title, currentPage: currentPage, user: user }) %>

<link rel="stylesheet" href="/css/forms.css">

<div class="page-header-forms">
    <h1><i class="fas fa-link" style="color: var(--accent); margin-right: 12px;"></i>Интеграции форм</h1>
    <button class="btn btn-primary" onclick="FormsModule.showModal('addFormModal')">
        <i class="fas fa-plus"></i> Добавить интеграцию
    </button>
</div>

<div class="controls-bar">
    <div class="search-box">
        <i class="fas fa-search"></i>
        <input type="text" id="searchForms" placeholder="Поиск по ID, названию, каналу или серверу...">
    </div>
    <div class="filter-box">
        <div class="custom-select-wrapper" id="customSelectWrapper">
            <div class="custom-select-trigger">
                <span id="customSelectLabel">Все сервера</span>
                <i class="fas fa-chevron-down select-arrow"></i>
            </div>
            <div class="custom-options" id="customSelectOptions">
                </div>
        </div>
    </div>
    <div class="bulk-actions">
        <button class="bulk-delete-btn" id="bulkDeleteBtn">
            <i class="fas fa-trash-alt"></i> Удалить выбранные
        </button>
    </div>
</div>

<div class="card" style="padding:0; overflow-x: auto;">
    <table class="data-table">
        <thead>
            <tr>
                <th style="width: 3%;">
                    <div class="custom-pure-checkbox" id="selectAllInput" data-checked="false">
                        <span class="checkmark"></span>
                    </div>
                </th>
                <th style="width: 15%;">ID формы</th>
                <th style="width: 18%;">Сервер</th>
                <th style="width: 18%;">Канал</th>
                <th style="width: 12%;">Название</th>
                <th style="width: 18%;">Роли для пинга</th>
                <th style="width: 8%;">Статус</th>
                <th style="width: 8%;">Действия</th>
            </tr>
        </thead>
        <tbody id="formsList">
            <tr><td colspan="8" class="empty-state"><i class="fas fa-spinner fa-spin"></i><p>Загрузка данных...</p></td></tr>
        </tbody>
    </table>
</div>

<div id="addFormModal" class="modal" role="dialog" aria-labelledby="addModalTitle" aria-hidden="true">
    <div class="modal-content">
        <h3 id="addModalTitle" style="margin-bottom:1.5rem; display: flex; align-items: center; gap: 8px;">
            <i class="fas fa-plus-circle" style="color: var(--accent);"></i>Новая интеграция
        </h3>
        <form id="addForm">
            <div class="form-group">
                <label><i class="fas fa-id-card"></i> ID или ссылка на форму</label>
                <input type="text" name="formId" placeholder="https://docs.google.com/forms/d/.../viewform" required>
            </div>
            <div class="form-group">
                <label><i class="fas fa-server"></i> Discord Guild ID</label>
                <input type="text" name="guildId" placeholder="ID сервера Discord" required>
            </div>
            <div class="form-group">
                <label><i class="fas fa-hashtag"></i> Discord Channel ID</label>
                <input type="text" name="channelId" placeholder="Включите режим разработчика в Discord" required>
            </div>
            <div class="form-group">
                <label><i class="fas fa-tag"></i> Название формы</label>
                <input type="text" name="formName" placeholder="Например: Заявка на лидерство">
            </div>
            <div class="form-group">
                <label><i class="fas fa-at"></i> ID роли для пинга</label>
                <input type="text" name="pingRoleId" placeholder="ID первой роли">
            </div>
            <div class="form-group">
                <label><i class="fas fa-at"></i> ID второй роли</label>
                <input type="text" name="pingRoleId2" placeholder="ID второй роли">
            </div>
            <div class="modal-buttons">
                <button type="button" class="btn btn-secondary" onclick="FormsModule.closeModal('addFormModal')">Отмена</button>
                <button type="submit" class="btn btn-primary">Создать интеграцию</button>
            </div>
        </form>
    </div>
</div>

<div id="editFormModal" class="modal" role="dialog" aria-labelledby="editModalTitle" aria-hidden="true">
    <div class="modal-content">
        <h3 id="editModalTitle" style="margin-bottom:1.5rem; display: flex; align-items: center; gap: 8px;">
            <i class="fas fa-edit" style="color: var(--accent);"></i>Редактирование интеграции
        </h3>
        <form id="editForm">
            <input type="hidden" name="formId" id="editFormId">
            <div class="form-group">
                <label><i class="fas fa-tag"></i> Название формы</label>
                <input type="text" name="formName" id="editFormName">
            </div>
            <div class="form-group">
                <label><i class="fas fa-server"></i> Discord Guild ID</label>
                <input type="text" name="guildId" id="editGuildId" required>
            </div>
            <div class="form-group">
                <label><i class="fas fa-hashtag"></i> Discord Channel ID</label>
                <input type="text" name="channelId" id="editChannelId" required>
            </div>
            <div class="form-group">
                <label><i class="fas fa-at"></i> ID роли для пинга</label>
                <input type="text" name="pingRoleId" id="editPingRoleId">
            </div>
            <div class="form-group">
                <label><i class="fas fa-at"></i> ID второй роли</label>
                <input type="text" name="pingRoleId2" id="editPingRoleId2">
            </div>
            <div class="modal-buttons">
                <button type="button" class="btn btn-secondary" onclick="FormsModule.closeModal('editFormModal')">Отмена</button>
                <button type="submit" class="btn btn-primary">Сохранить изменения</button>
            </div>
        </form>
    </div>
</div>

<div id="confirmDeleteModal" class="modal" role="dialog" aria-labelledby="deleteModalTitle" aria-hidden="true">
    <div class="modal-content">
        <i class="fas fa-exclamation-triangle" style="font-size: 3rem; color: var(--danger); margin-bottom: 1rem;"></i>
        <h3 id="deleteModalTitle" style="margin-bottom: 0.5rem;">Удаление интеграции</h3>
        <p id="deleteFormName" style="color: var(--text-dim); margin-bottom: 1.5rem;">Вы уверены?</p>
        <div class="confirm-buttons">
            <button type="button" id="deleteCancelBtn" class="btn btn-secondary">Отмена</button>
            <button type="button" id="deleteConfirmBtn" class="btn btn-danger">Удалить</button>
        </div>
    </div>
</div>

<script src="/js/forms.js"></script>

<%- include('layout', { part: 'footer' }) %>